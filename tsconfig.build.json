{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowImportingTsExtensions": false,
    "moduleResolution": "node",
    "module": "ESNext"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
